# Copy to .env and adjust. Never commit .env.

DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=change-me-in-development-use-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Set to False when using PostgreSQL (recommended for staging/production parity).
USE_SQLITE=True

# PostgreSQL
DATABASE_URL=postgresql://webmarketplace:webmarketplace@localhost:5432/webmarketplace
POSTGRES_DB=webmarketplace
POSTGRES_USER=webmarketplace
POSTGRES_PASSWORD=webmarketplace
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Email / contact
DEFAULT_FROM_EMAIL=noreply@anunciateya.com
EMAIL_FROM_NAME=AnunciateYa
CONTACT_EMAIL=hola@anunciateya.com
EMAIL_HOST=localhost
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_USE_TLS=True

# Identidad visual pública (rutas relativas a static/)
# BRAND_LOGO_PATH=img/AnunciateYa_Logo.png
# BRAND_LOGO_WHITE_PATH=img/AnunciateYa_Logo_White.png
# BRAND_FAVICON_PATH=img/AnunciateYa_Favicon.png
# BRAND_HERO_BG_PATH=img/AnunciateYa_HeroBackground.webp
# BRAND_FONT_DISPLAY=General Sans
# BRAND_FONT_BODY=General Sans
# BRAND_THEME_COLOR=#3CBB6B

# Redes (footer; vacío = no mostrar). YouTube / LinkedIn listos para cuando existan perfiles.
SOCIAL_INSTAGRAM_URL=https://www.instagram.com/anunciateya.ec/
SOCIAL_TIKTOK_URL=https://www.tiktok.com/@anunciateya.ec
# SOCIAL_YOUTUBE_URL=
# SOCIAL_LINKEDIN_URL=

# Google Tag Manager — not loaded when DEBUG=True or on /admin/ (see apps.core.context_processors).
# Optional: GOOGLE_TAG_MANAGER_ID= to disable in production/staging.
GOOGLE_TAG_MANAGER_ID=GTM-KSQPQ3PZ

# Meta Pixel (Events Manager) — same DEBUG/admin rules as GTM. Empty META_PIXEL_ID= disables.
META_PIXEL_ID=967148372336400

# Meta domain verification (Business Suite). Empty FACEBOOK_DOMAIN_VERIFICATION= omits the meta tag.
FACEBOOK_DOMAIN_VERIFICATION=n8la58cezu7afq4v0f07txp84iqppu

# Hosting membership shown inside the custom admin panel only.
# Dates use YYYY-MM-DD.
HOSTING_MEMBERSHIP_START_DATE=2026-01-01
HOSTING_MEMBERSHIP_EXPIRES_DATE=2027-01-01
HOSTING_RENEWAL_URL=https://altovalleit.com/hosting/

# Mapbox (solo inmuebles: geocoder en formulario y mapa en detalle).
# MAPBOX_ENABLED=False desactiva la integración aunque exista token.
# MAPBOX_PUBLIC_TOKEN=pk.eyJ...
# MAPBOX_STYLE_URL=mapbox://styles/mapbox/streets-v12
MAPBOX_ENABLED=False
MAPBOX_PUBLIC_TOKEN=
MAPBOX_STYLE_URL=mapbox://styles/mapbox/streets-v12

# Production-only (set via hosting)
# DJANGO_SETTINGS_MODULE=config.settings.production
#   Tras Nginx con TLS: si el proxy envía X-Forwarded-Proto: https, Django no fuerza redirect mal.
#   Pruebas directas a Gunicorn deben enviar Host + X-Forwarded-Proto como haría Nginx.

# Media uploads on Amazon S3 (production).
# Leave AWS_STORAGE_BUCKET_NAME empty to keep using local MEDIA_ROOT.
# Recommended: use a CloudFront distribution as AWS_S3_CUSTOM_DOMAIN and keep the bucket private with OAC.
# Existing local files must be uploaded preserving paths under the AWS_S3_MEDIA_LOCATION prefix.
# Example object key for media/listings/2026/06/foto.jpg:
#   aws s3 sync media/ s3://your-bucket-name/media/
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
AWS_S3_MEDIA_LOCATION=media
AWS_S3_CUSTOM_DOMAIN=
AWS_QUERYSTRING_AUTH=False
AWS_S3_MEDIA_CACHE_CONTROL=public, max-age=31536000, immutable
# Prefer IAM role/hosting secrets in production. Only set these when the host cannot provide an AWS role.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
